# Next.js — copy to .env.local (never commit .env.local).

# --- Local dev: FastAPI on this machine ---
NEXT_PUBLIC_API_URL=http://localhost:8000

# --- Production split host (recommended explicit; peopleopslab.in also infers this in the browser) ---
# NEXT_PUBLIC_API_URL=https://api.peopleopslab.in

# --- Optional: same-origin API proxy (set RELAY_BACKEND_ORIGIN when building — see README) ---
# NEXT_PUBLIC_USE_API_RELAY=1
# (build-time server env, not prefixed NEXT_PUBLIC:) RELAY_BACKEND_ORIGIN=https://api.peopleopslab.in

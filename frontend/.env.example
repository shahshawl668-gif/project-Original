# Next.js — copy to .env.local (never commit .env.local).
#
# Prefer the same-origin proxy in production:
#   /api/proxy/api/*  →  ${BACKEND_URL}/api/*
# This avoids browser-side CORS / mixed content issues entirely.

# ----------------------------------------------------------------------------
# 1) Local dev: browser talks directly to FastAPI on this PC.
# ----------------------------------------------------------------------------
NEXT_PUBLIC_API_URL=http://localhost:8000

# ----------------------------------------------------------------------------
# 2) Production on Vercel (peopleopslab.in): same-origin proxy.
#    Set on Vercel → Project → Settings → Environment Variables (Production).
#    NOT prefixed with NEXT_PUBLIC. The Next.js server reads it at runtime.
# ----------------------------------------------------------------------------
# BACKEND_URL=https://api.peopleopslab.in

# ----------------------------------------------------------------------------
# 3) Force the SPA to use the proxy on any hostname (e.g. preview deploys).
# ----------------------------------------------------------------------------
# NEXT_PUBLIC_USE_API_RELAY=1

# ----------------------------------------------------------------------------
# 4) Force the browser to skip the proxy and hit the API directly. Requires
#    the API to send `Access-Control-Allow-Origin` for this site.
# ----------------------------------------------------------------------------
# NEXT_PUBLIC_DIRECT_API=1
# NEXT_PUBLIC_API_URL=https://api.peopleopslab.in

# Next.js — copy to .env.local (never commit .env.local).

# --- Typical local dev: browser → FastAPI on this PC (no proxy) ---
NEXT_PUBLIC_API_URL=http://localhost:8000

# --- Prod on Vercel (peopleopslab.in): automatic /api/proxy needs server env ---
# In Vercel dashboard (Production), NOT as NEXT_PUBLIC:
# BACKEND_URL=https://api.peopleopslab.in

# --- Force SPA to call BACKEND_URL only via proxy on any hostname ---
# NEXT_PUBLIC_USE_API_RELAY=1

# --- Force browser to skip /api/proxy (direct calls; requires CORS on API + NEXT_PUBLIC_API_URL) ---
# NEXT_PUBLIC_DIRECT_API=1
# NEXT_PUBLIC_API_URL=https://api.peopleopslab.in

# --- Local proxy test ---
# NEXT_PUBLIC_USE_API_RELAY=1
# BACKEND_URL=http://127.0.0.1:8000

# FastAPI — copy to .env (never commit .env).
#
# Production for peopleopslab.in:
#   - Public API URL: https://api.peopleopslab.in
#   - Browsers load the Next app from https://peopleopslab.in — those origins go in CORS_ORIGINS.

DATABASE_URL=sqlite:///./payroll_dev.db

# REQUIRED in production — use a long random string (openssl rand -hex 32)
JWT_SECRET=change-me-in-production-use-long-random-secret

# Origins that may send Authorization / credentialed requests to this API.
# Production: include where Next.js is served (apex + www). Local: localhost:3000.
CORS_ORIGINS=http://localhost:3000,https://peopleopslab.in,https://www.peopleopslab.in

# Production: false. Local dev only: true skips JWT and uses the built-in system user.
ALLOW_ANONYMOUS_API=false

# Optional: PostgreSQL (see requirements-postgres.txt)
# DATABASE_URL=postgresql+psycopg2://USER:PASSWORD@HOST:5432/DBNAME

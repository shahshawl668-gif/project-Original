# FastAPI — copy to .env (never commit .env).
#
# Production for peopleopslab.in:
#   - Public API URL:        https://api.peopleopslab.in
#   - Web app origins:       https://peopleopslab.in, https://www.peopleopslab.in
#   - Hosting platform vars (Render/Railway):
#       PORT, DATABASE_URL → automatically injected
#
# Local dev: SQLite + permissive defaults.

# Runtime env: dev | staging | production
ENV=dev

# --- Database ----------------------------------------------------------------
# Local dev (SQLite):
DATABASE_URL=sqlite:///./payroll_dev.db
# Production examples (use ONE):
# DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DBNAME
# DATABASE_URL=postgres://USER:PASSWORD@HOST:5432/DBNAME      # Render-style; auto-normalised

# --- Auth --------------------------------------------------------------------
# REQUIRED in production. Generate: `openssl rand -hex 48`
JWT_SECRET=change-me-in-production-use-long-random-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# --- CORS --------------------------------------------------------------------
# Comma-separated browser origins that may call this API.
CORS_ORIGINS=http://localhost:3000,https://peopleopslab.in,https://www.peopleopslab.in
# Optional regex match for preview deployments, e.g. Vercel preview URLs.
# CORS_ORIGIN_REGEX=^https://.*-myteam\.vercel\.app$

# --- Behaviour ---------------------------------------------------------------
# Production MUST be false. Forced to false automatically when ENV=production.
ALLOW_ANONYMOUS_API=false

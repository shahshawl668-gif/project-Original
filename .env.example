# Database (used by backend + docker-compose)
POSTGRES_USER=payroll
POSTGRES_PASSWORD=payroll
POSTGRES_DB=payroll_db
POSTGRES_PORT=5432

DATABASE_URL=postgresql://payroll:payroll@localhost:5432/payroll_db

# JWT
JWT_SECRET=replace-with-long-random-string-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS (comma-separated)
CORS_ORIGINS=http://localhost:3000

# Ports
BACKEND_PORT=8000
FRONTEND_PORT=3000

# Frontend → backend (browser calls this URL)
NEXT_PUBLIC_API_URL=http://localhost:8000
